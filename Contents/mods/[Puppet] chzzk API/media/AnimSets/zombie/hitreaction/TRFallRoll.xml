<?xml version="1.0" encoding="utf-8"?>
<!-- 트레이서 낙법 구르기: Dash 모드(Bob_rollaction)의 롤 애님을 TR 네임스페이스
     사본(TR_RollAction.X)으로 재생. 2층 이상 낙하(fallTime>=70) 착지 순간
     Lua(updateTracer)가 TRFallRolling=true + hitreaction=TRFallRoll을 세팅해
     발동한다. 완료 판정은 검증된 Started-변수 패턴: End 이벤트가
     TRFallRolling=false로 자가 종료 -> Lua가 hitreaction 잔여값 정리.
     deferredBoneAxis Y = 루트모션 전방 구르기. SpeedScale은 Dash 원본값 2.88. -->
<animNode>
	<m_Name>TRFallRoll</m_Name>
	<m_AnimName>TR_RollAction</m_AnimName>
	<m_deferredBoneAxis>Y</m_deferredBoneAxis>
	<m_Looped>false</m_Looped>
	<m_EarlyBlendOut>true</m_EarlyBlendOut>
	<m_SpeedScale>2.88</m_SpeedScale>
	<m_BlendTime>0.20</m_BlendTime>
	<m_BlendOutTime>0.3</m_BlendOutTime>
	<m_Conditions>
		<m_Name>hitreaction</m_Name>
		<m_Type>STRING</m_Type>
		<m_StringValue>TRFallRoll</m_StringValue>
	</m_Conditions>
	<m_Conditions>
		<m_Name>TRFallRolling</m_Name>
		<m_Type>BOOL</m_Type>
		<m_BoolValue>true</m_BoolValue>
	</m_Conditions>
	<m_Events>
		<m_EventName>SetVariable</m_EventName>
		<m_Time>End</m_Time>
		<m_ParameterValue>TRFallRolling=false</m_ParameterValue>
	</m_Events>
</animNode>
